# Server
PORT=3000
NODE_ENV=development

# Persistence
DATABASE_PATH=./data/artefactor.db
ARTEFACTOR_PAYLOAD_DIR=./data/payloads
MIGRATIONS_DIR=./src/infra/db/migrations

# Static client (built by `pnpm build:client`)
CLIENT_DIR=./dist/client

BETTER_AUTH_SECRET=        # required in production; openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000
AUTH_TRUSTED_ORIGINS=http://localhost:5173
